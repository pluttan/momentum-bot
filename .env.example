# ==========================================================
# momentum-bot configuration template
# Copy to .env and fill in actual values. .env is gitignored.
# ==========================================================

# === Mode ===
# SCAN_ONLY — печатает ranking + picks, не торгует
# PAPER     — виртуальная торговля (безопасно для 1-й недели)
# LIVE      — реальные ордера (требует BINANCE_API_KEY/SECRET)
MODE=PAPER

# === Capital ===
# Total USDT capital. Для testing начинай с $100-500.
TOTAL_CAPITAL=1000

# === Binance API (только для MODE=LIVE) ===
# 1. zайди на binance.com → API Management → Create API
# 2. Enable: Trading + Reading
# 3. DISABLE: Withdrawals (критично!)
# 4. IP whitelist: server IP (или leave unrestricted для remote access)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# === Telegram (обязательно для PAPER + LIVE) ===
# 1. @BotFather → /newbot → запиши токен
# 2. Узнай свой chat_id: send /start в бот, потом
#    curl "https://api.telegram.org/bot<TOKEN>/getUpdates" → найди "chat":{"id":...}
# 3. TELEGRAM_OWNER_ID = твой user_id (тот же что chat_id для private chat)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_OWNER_ID=

# === Strategy params (defaults = classic conservative) ===
# VARIANT: classic | dual | timeseries
#   classic (default)    — top-N by past return, smaller size, higher DD
#   dual                 — top-N AND > BTC return (selective)
#   timeseries           — all positive-momentum, diversified (lower DD)
VARIANT=classic

# Lookback window для ranking (days)
LOOKBACK_DAYS=14

# Hold period до rebalance (days)
HOLD_DAYS=60

# Number of positions для classic/dual
TOP_N=3

# Max positions для timeseries variant
TIMESERIES_MAX_N=8

# Stop-loss % per position
STOP_LOSS_PCT=-0.03

# === Fees ===
# BNB discount gives 0.075% vs 0.1% regular
USE_BNB_DISCOUNT=true
FEE_RATE=0.001
BNB_FEE_RATE=0.00075

# === Risk caps ===
# MAX_DRAWDOWN_PCT: bot halts if equity drops > X% from peak.
# Real maxDD для momentum configs ~-45 до -62% (honest tracking!).
# Default 0.30 triggers early для timeseries. Set 0.60 если deploy timeseries.
MAX_DRAWDOWN_PCT=0.30

# Max daily loss в USD
MAX_DAILY_LOSS_USD=300

# === Schedule ===
# Rebalance happens на DAY_OF_MONTH каждого месяца
REBALANCE_DAY_OF_MONTH=1

# Main loop check interval (для stop-loss). 300s = 5 min.
CHECK_INTERVAL_SEC=300

# Daily report hour (UTC)
DAILY_REPORT_HOUR=9
